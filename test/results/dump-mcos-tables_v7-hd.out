cat_scalar = categorical:
  Categories: {blue, green, red}
  Values: red, green, blue, red
cat_array = categorical:
  Categories: {high, low, medium}
  Values: low, high, medium, low
cat_3D = categorical:
  Categories: {maybe, no, yes}
  Values: yes, yes, no, no, maybe, maybe, yes, yes, no, no, ... (12 total)
cat_unordered = categorical:
  Categories: {cold, warm, hot}
  Values: cold, hot, warm
cat_ordered = categorical:
  Categories: {small, medium, large}
  Values: small, medium, large
cat_from_numeric = categorical:
  Categories: {low, medium, high}
  Values: low, medium, high, medium, low
cat_empty = categorical:
cat_missing = categorical:
  Categories: {cat, dog, mouse}
  Values: cat, <undefined>, dog, mouse
cat_string = categorical:
  Categories: {autumn, spring, summer, winter}
  Values: spring, summer, autumn, winter
cat_mixed_case = categorical:
  Categories: {OFF, ON, On, off, on}
  Values: On, off, OFF, ON, on
