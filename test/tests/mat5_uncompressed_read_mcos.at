AT_SETUP([Read MCOS bugv6 la])
AT_KEYWORDS([mcos])
AT_SKIP_IF([test $MCOS -ne 1])
AT_CHECK([cp $srcdir/results/read-mcos-bugv6-la.out expout
          $builddir/test_mat readvar $srcdir/datasets/bugv6.mat la],[0],[expout],[])
AT_CLEANUP

