AT_SETUP([Calculate a set of subscripts from a linear index])
AT_KEYWORDS([subscript_api])
AT_CHECK([cp $srcdir/results/ind2sub.out expout
          $builddir/test_mat ind2sub],[0],[expout],[])
AT_CLEANUP

AT_SETUP([Calculate the linear index from subscript values])
AT_KEYWORDS([subscript_api])
AT_CHECK([cp $srcdir/results/sub2ind.out expout
          $builddir/test_mat sub2ind],[0],[expout],[])
AT_CLEANUP
